# EIA Open Data v2 API key (https://www.eia.gov/opendata/register.php).
# Free; ~5000 req/hr; required for the EIA v2 adapter.
EIA_API_KEY=<replace-with-your-eia-key>

# FRED API key (https://fredaccount.stlouisfed.org/apikeys). Free.
# Required for the FRED adapter (transformer PPI, power demand, etc.).
FRED_API_KEY=<replace-with-your-fred-key>

# UN Comtrade API key (https://comtradeplus.un.org/). Free tier with
# daily limits. Required for the comtrade ingest (HBM / transformer
# trade flows). Without it, the comtrade source is SKIPPED.
COMTRADE_API_KEY=<replace-with-your-comtrade-key>

# Optional: override the default database URL.
# sqlite (default):  DATABASE_URL=sqlite:///./data/processed/bottlewatch.db
# in-memory (tests): DATABASE_URL=sqlite:///:memory:
# Postgres (v1.1):   DATABASE_URL=postgresql+psycopg://user:pass@host:5432/bottlewatch
#                     (the +psycopg suffix selects the psycopg3 driver; a bare
#                     postgresql:// URL is also accepted and auto-rewritten)
# DATABASE_URL=

# Optional: override the environment (dev | test | prod).
# APP_ENV=dev

# M2 web surface: comma-separated list of CORS origins. The default
# (`http://localhost:3000`) covers the Next.js dev server. Override for
# staging / prod. The API is read-only except for /thesis (POST/DELETE).
# CORS_ORIGINS=["http://localhost:3000"]
